rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User Profile Rules
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) 
        && isValidUserPayload(incoming());
      allow update: if isOwner(userId) 
        && isValidUserPayload(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'updatedAt']);
    }

    function isValidUserPayload(data) {
      return data.uid == request.auth.uid
        && data.email is string
        && (data.displayName == null || data.displayName is string)
        && (data.photoURL == null || data.photoURL is string)
        && data.email.size() <= 256;
    }

    // Edited Images Rules
    match /images/{imageId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() 
        && incoming().userId == request.auth.uid
        && isValidImagePayload(incoming());
      // No updates or deletes allowed for history integrity, 
      // but if we wanted to allow deletion:
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    function isValidImagePayload(data) {
      return data.userId == request.auth.uid
        && data.originalImageUrl is string
        && data.editedImageUrl is string
        && data.filterType is string
        && data.createdAt is string
        && data.originalImageUrl.size() <= 2048
        && data.editedImageUrl.size() <= 1048576 // Base64 can be large, but Firestore docs limit is 1MB
        && data.filterType.size() <= 50;
    }
  }
}
